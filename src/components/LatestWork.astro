---
import { getCollection } from "astro:content";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getPostSlug } from "@/utils/getPostPaths";
import FeaturedProjectCard from "./FeaturedProjectCard.astro";

// Fetch and sort posts
const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.slice(0, 3);

// Tag mapping for categorization
const tagCategoryMap: Record<string, string> = {
  "data-structures": "Data Structures",
  "memory-allocation": "Memory Management",
  "memory-handaling": "Memory Management",
  "memory-with-no-limitation": "Memory Management",
  tree: "Data Structures",
  intro: "Introduction",
  c: "Backend",
};
---

<section
  id="latest-work"
  class="border-border dark:border-zinc-800 border-b bg-transparent dark:bg-transparent py-12 sm:py-16 lg:py-20"
>
  <div class="app-layout">
    <!-- Section Header -->
    <div class="mb-12 space-y-3">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl">
        Latest Work
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-300">
        Explore my recent engineering articles and technical deep dives.
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="grid gap-6 sm:gap-8 lg:grid-cols-1">
      {
        recentPosts.map((post) => {
          // Extract category tags from post tags and deduplicate
          const categoryTags = post.data.tags
            .filter((tag) => tagCategoryMap[tag])
            .map((tag) => tagCategoryMap[tag]);

          // Deduplicate tags using Set
          const uniqueTags = [...new Set(categoryTags)];

          // Add a default "Engineering" tag if no category found
          const displayTags = uniqueTags.length > 0 ? uniqueTags : ["Engineering"];

          // Generate slug
          const postSlug = getPostSlug(post.id, post.filePath);

          return (
            <FeaturedProjectCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.pubDatetime.toISOString()}
              tags={displayTags}
              href={`/posts/${postSlug}/`}
            />
          );
        })
      }
    </div>

    <!-- View All Link -->
    <div class="mt-12 text-center">
      <a
        href="/posts"
        class="inline-flex items-center font-medium text-accent dark:text-green-400 hover:underline transition-all"
      >
        View all articles
        <svg
          class="ml-2 h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13 7l5 5m0 0l-5 5m5-5H6"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  #latest-work {
    animation: fadeIn 0.8s ease-out 0.2s both;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
