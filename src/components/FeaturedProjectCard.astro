---
interface Props {
  title: string;
  description?: string;
  date: string;
  tags?: string[];
  href?: string;
}

const { title, description, date, tags = [], href = "#" } = Astro.props;

// Format date
const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a
  href={href}
  class="group block rounded-lg border border-border dark:border-zinc-700 bg-white dark:bg-transparent p-6 transition-all duration-200 hover:border-accent hover:shadow-md sm:p-8"
>
  <div class="flex flex-col space-y-4">
    <!-- Header with date -->
    <div class="flex items-start justify-between gap-4">
      <div class="flex-1">
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white group-hover:text-accent transition-colors">
          {title}
        </h3>
      </div>
      <time class="text-sm font-medium text-slate-600 dark:text-slate-400 whitespace-nowrap">
        {formattedDate}
      </time>
    </div>

    <!-- Description -->
    {
      description && (
        <p class="text-base text-slate-600 dark:text-slate-300 leading-relaxed">
          {description}
        </p>
      )
    }

    <!-- Tags -->
    {
      tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 pt-2">
          {tags.map((tag) => (
            <span class="inline-flex items-center rounded-full bg-slate-100 dark:bg-zinc-900/60 px-3 py-1 text-xs font-medium text-slate-700 dark:text-slate-300">
              {tag}
            </span>
          ))}
        </div>
      )
    }

    <!-- Read More indicator -->
    <div class="text-sm font-medium text-accent group-hover:translate-x-1 transition-transform">
      Read more →
    </div>
  </div>
</a>

<style>
  a {
    transition: all 0.2s ease;
  }
</style>
