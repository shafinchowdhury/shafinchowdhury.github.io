---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import ProfessionalHero from "@/components/ProfessionalHero.astro";
import LatestWork from "@/components/LatestWork.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const rankedPosts = sortedPosts
  .map(post => {
    const popularityScore =
      typeof post.data.popularity === "number" ? post.data.popularity : 0;
    const updatedAt = new Date(
      post.data.modDatetime ?? post.data.pubDatetime
    ).getTime();
    const ageDays = Math.max(0, (Date.now() - updatedAt) / 86400000);
    const recencyScore = Math.max(0, 10000 - ageDays);
    const featuredBonus = post.data.featured ? 10000 : 0;

    return {
      ...post,
      score: popularityScore + recencyScore + featuredBonus,
    };
  })
  .sort(
    (a, b) =>
      b.score - a.score ||
      new Date(b.data.modDatetime ?? b.data.pubDatetime).getTime() -
        new Date(a.data.modDatetime ?? a.data.pubDatetime).getTime()
  );
const featuredPosts = rankedPosts.slice(0, postsConfig.perIndex);
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <ProfessionalHero
      imageUrl="https://cdn.shafinchowdhury.dev/blogs/home-page/598329222_3693489057452548_6311579749096457581_n.jpg"
    >
      <div slot="socials" class="flex flex-wrap items-center gap-2">
        <Socials />
        <a
          target="_blank"
          href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
          aria-label="RSS Feed"
          title="RSS Feed"
        >
          <IconRss width={20} height={20} class="stroke-accent scale-100" />
          <span class="sr-only">RSS Feed</span>
        </a>
      </div>
    </ProfessionalHero>

    <LatestWork />

    {
      featuredPosts.length > 0 && (
        <section id="featured" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.featured}
          </h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
